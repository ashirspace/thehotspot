generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MessageStatus {
  DRAFT
  APPROVED
  SENT
  SKIPPED
}

enum RecipientSource {
  LINKEDIN
  CSV
  EXCEL
  MANUAL
}

enum CampaignAudienceType {
  SINGLE_PERSON
  ENTIRE_COMPANY
  CUSTOM_CATEGORY
}

enum ActivityType {
  DRAFT_CREATED
  APPROVED
  SENT
  OPENED
  RESPONDED
  SKIPPED
  IMPORTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  linkedinId    String?   @unique
  headline      String?
  company       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  campaigns     Campaign[]
  recipients    Recipient[]
  imports       ImportBatch[]
  messages      DirectMessage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Recipient {
  id              String          @id @default(cuid())
  ownerId         String
  firstName       String
  lastName        String?
  fullName        String
  linkedinUrl     String?
  email           String?
  company         String?
  role            String?
  profession      String?
  location        String?
  category        String?
  profileSummary  String?         @db.Text
  source          RecipientSource @default(MANUAL)
  importedBatchId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  owner         User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  importedBatch ImportBatch?     @relation(fields: [importedBatchId], references: [id], onDelete: SetNull)
  messages      DirectMessage[]

  @@index([ownerId, company])
  @@index([ownerId, role])
  @@index([ownerId, category])
}

model Campaign {
  id               String               @id @default(cuid())
  ownerId          String
  name             String
  description      String               @db.Text
  audienceType     CampaignAudienceType @default(CUSTOM_CATEGORY)
  targetCompany    String?
  targetRole       String?
  targetProfession String?
  targetCategory   String?
  baseMessage      String               @db.Text
  status           String               @default("SETUP")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  owner      User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  messages   DirectMessage[]
  contexts   CampaignContext[]
  activities ActivityEvent[]

  @@index([ownerId, createdAt])
}

model CampaignContext {
  id         String   @id @default(cuid())
  campaignId String
  title      String
  kind       String
  content    String   @db.Text
  url        String?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model DirectMessage {
  id             String        @id @default(cuid())
  ownerId        String
  campaignId     String?
  recipientId    String?
  subject        String?
  body           String        @db.Text
  generatedBody  String?       @db.Text
  status         MessageStatus @default(DRAFT)
  openedAt       DateTime?
  respondedAt    DateTime?
  sentAt         DateTime?
  skippedReason  String?
  approvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  owner      User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  campaign   Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  recipient  Recipient?      @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  activities ActivityEvent[]

  @@index([ownerId, status])
  @@index([campaignId])
  @@index([recipientId])
}

model ActivityEvent {
  id         String       @id @default(cuid())
  campaignId String?
  messageId  String?
  type       ActivityType
  metadata   Json?
  createdAt  DateTime     @default(now())

  campaign Campaign?      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  message  DirectMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([messageId, createdAt])
}

model ImportBatch {
  id            String      @id @default(cuid())
  ownerId       String
  filename      String
  source        String
  rowCount      Int
  validCount    Int
  invalidCount  Int
  mapping       Json
  validationLog Json
  createdAt     DateTime    @default(now())

  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  recipients Recipient[]

  @@index([ownerId, createdAt])
}
