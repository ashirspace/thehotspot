{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/crons/daily",
      "schedule": "0 9 * * *"
    }
  ],
  "functions": {
    "api/crons/daily.js": {
      "maxDuration": 60
    }
  }
}
