DATABASE_URL="postgresql://user:password@ep-your-branch-pooler.region.aws.neon.tech/thehotspot?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-your-branch.region.aws.neon.tech/thehotspot?sslmode=require"

OPENAI_API_KEY="server-only-openai-key"
OPENAI_MODEL="gpt-4o-mini"

ESP_PROVIDER="resend"
ESP_API_KEY="server-only-esp-key"
ESP_WEBHOOK_SECRET="replace-with-esp-webhook-secret"
WEBHOOK_SIGNING_SECRET="replace-with-generic-webhook-secret"
CRON_SECRET="replace-with-cron-secret"
UNSUBSCRIBE_TOKEN_SECRET="replace-with-unsubscribe-token-secret"
APP_BASE_URL="http://localhost:5173"

SENTRY_DSN=""
PLAUSIBLE_DOMAIN="thehotspot.in"

# Local admin — comma-separated emails granted requireAdmin() access
# Used by: api/admin/* endpoints and any page that calls requireAdmin()
ADMIN_EMAILS="admin@localhost,ashirayaan.work@gmail.com"

# Seed script defaults — override when running: npm run db:admin
ADMIN_EMAIL="admin@localhost"
ADMIN_PASSWORD="admin1234"
ADMIN_NAME="Local Admin"

# Google OAuth — create at console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: ${APP_BASE_URL}/api/auth?action=google-callback
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudflare Turnstile — create at dash.cloudflare.com → Turnstile
# For local dev use test keys: site=1x00000000000000000000AA, secret=1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"
